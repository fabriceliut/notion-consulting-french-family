---
import Logo from "./Logo.astro";
import { NAV_LINKS, withBase } from "../lib/site";

interface Props {
  variant?: "full" | "minimal";
}
const { variant = "full" } = Astro.props;
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href={withBase("/")} aria-label="Collectif Notion France — accueil">
      <Logo size={28} />
      <span class="brand-text">Collectif Notion France</span>
    </a>

    {
      variant === "full" ? (
        <>
          <div class="nav-panel" id="site-menu">
            <nav class="nav-nav" aria-label="Navigation principale">
              <ul class="nav-links">
                {NAV_LINKS.map((link) => (
                  <li>
                    <a href={withBase(link.href)}>{link.label}</a>
                  </li>
                ))}
              </ul>
            </nav>
            <div class="nav-actions">
              <a class="btn btn--secondary" href={withBase("/#contact")}>
                Rejoindre le collectif
              </a>
              <a class="btn btn--primary" href={withBase("/#consultants")}>
                Trouver un consultant
              </a>
            </div>
          </div>
          <button
            class="nav-toggle"
            type="button"
            aria-label="Ouvrir le menu"
            aria-controls="site-menu"
            aria-expanded="false"
          >
            <span class="bars" aria-hidden="true">
              <span class="bar" />
              <span class="bar" />
              <span class="bar" />
            </span>
          </button>
        </>
      ) : (
        <div class="nav-actions nav-actions--minimal">
          <a class="btn btn--primary" href={withBase("/#consultants")}>
            <span class="lbl-long">Tous les consultants</span>
            <span class="lbl-short">Consultants</span>
          </a>
        </div>
      )
    }
  </div>
</header>
