---
interface Tag {
  label: string;
  color: "blue" | "green" | "purple" | "orange" | "pink" | "gray" | "yellow";
}
interface Props {
  tags: Tag[];
  class?: string;
}
const { tags, class: className } = Astro.props;
---

<div class:list={["tags", className]}>
  {tags.map((tag) => <span class={`tag tag--${tag.color}`}>{tag.label}</span>)}
</div>
