---
// Marque custom du collectif (mark éditorial « lignes de doc » + accent bleu).
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "brand-mark" } = Astro.props;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 28 28"
  role="img"
  aria-label="Collectif Notion France"
  class={className}
>
  <rect x="0" y="0" width="28" height="28" rx="7" fill="#37352f"></rect>
  <rect x="7" y="7.5" width="14" height="2.2" rx="1.1" fill="#ffffff"></rect>
  <rect x="7" y="12.9" width="14" height="2.2" rx="1.1" fill="#ffffff" opacity="0.72"></rect>
  <rect x="7" y="18.3" width="9" height="2.2" rx="1.1" fill="#ffffff" opacity="0.5"></rect>
  <rect x="18" y="18.3" width="3" height="2.2" rx="1.1" fill="#2383e2"></rect>
</svg>
